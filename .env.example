# Copy this file to .env and fill in your values.
# The .env file is gitignored and must never be committed.

# Required: Anthropic API key used by the LLM multi-agent backtest and the
# memorization probe (the `agents` and `probe` CLI commands).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the models used by the agent graph.
# Defaults are set in src/tradinglab/config.py if these are unset.
# TRADINGLAB_QUICK_MODEL is the fast/cheap model for analyst passes.
# TRADINGLAB_DEEP_MODEL is the stronger model for debate and final decisions.
TRADINGLAB_QUICK_MODEL=claude-haiku-4-5
TRADINGLAB_DEEP_MODEL=claude-opus-4-8
